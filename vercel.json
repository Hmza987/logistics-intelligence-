{
  "version": 2,
  "devCommand": "npx --yes serve . --listen $PORT --no-clipboard",
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "/login",      "status": 302, "headers": { "Location": "/" } },
    { "src": "/logout",     "status": 302, "headers": { "Location": "/" } },
    { "src": "/api/(.*)",   "dest": "/api/$1" },
    { "src": "/data/(.*)",  "dest": "/data/$1" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
